# ==========================================
# TinkuBot Microservices
# Variables de Entorno Compartidas
# ==========================================

# ------------------------------------------
# CONFIGURACIÓN GENERAL
# ------------------------------------------
NODE_ENV=production
SERVER_HOST=0.0.0.0
LOG_LEVEL=INFO

# ------------------------------------------
# SUPABASE (Base de datos y autenticación)
# ------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-key
SUPABASE_URI=postgresql://postgres:password@host:5432/postgres?sslmode=require
SUPABASE_PROVIDERS_TABLE=providers
SUPABASE_PROVIDERS_BUCKET=tinkubot-providers

# ------------------------------------------
# DATABASE (Para servicios que usan SQL directo)
# ------------------------------------------
DATABASE_URL=postgresql://postgres:password@host:5432/postgres?sslmode=require

# ------------------------------------------
# OPENAI API
# ------------------------------------------
OPENAI_API_KEY=your-openai-api-key
OPENAI_CHAT_MODEL=gpt-4o-mini

# ------------------------------------------
# REDIS (Cache y sesiones)
# ------------------------------------------
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# ------------------------------------------
# FRONTEND
# ------------------------------------------
FRONTEND_SERVICE_PORT=5000
ADMIN_USER=admin
ADMIN_PASSWORD=your-admin-password
PROVIDERS_PENDING_LIMIT=100

# ------------------------------------------
# AI SERVICE CLIENTES
# ------------------------------------------
AI_SERVICE_CLIENTES_URL=http://ai-clientes:8001
CLIENTES_SERVER_PORT=8001
AI_SERVICE_CLIENTES_PORT=8001
WHATSAPP_CLIENTES_URL=http://wa-gateway:7000
WHATSAPP_PROVEEDORES_URL=http://wa-gateway:7000
WHATSAPP_CLIENTES_ACCOUNT_ID=bot-clientes
WHATSAPP_PROVEEDORES_ACCOUNT_ID=bot-proveedores
WA_ONBOARDING_STRATEGY=session_first_v1
WA_ONBOARDING_IMAGE_URL=https://example.com/path/to/onboarding-image.png
WA_PROVIDER_ONBOARDING_BTN_REGISTRARSE_HEADER_URL=https://example.com/path/to/provider-registration-header.png
WA_PROVIDER_ONBOARDING_DNI_FRONT_GUIDE_URL=https://example.com/path/to/provider-dni-front-guide.png
WA_PROVIDER_ONBOARDING_PROFILE_PHOTO_GUIDE_URL=https://example.com/path/to/provider-profile-photo-guide.png
WA_PROVIDER_SERVICES_IMAGE_URL=https://example.com/path/to/services-image.png
WA_PROVIDER_SOCIAL_NETWORK_IMAGE_URL=https://example.com/path/to/social-network-guide.png
WA_ONBOARDING_IMAGE_CAPTION=TinkuBot
WA_ONBOARDING_CONTINUE_LABEL=Continuar
WA_ONBOARDING_CONTINUE_ID=continue_onboarding
WA_ONBOARDING_FOOTER_TEXT=Al continuar aceptas nuestras condiciones.

# ------------------------------------------
# AI SEARCH
# ------------------------------------------
AI_SEARCH_PORT=8000
AI_SEARCH_INTERNAL_TOKEN=your-internal-token-here
EMBEDDINGS_TIMEOUT_SECONDS=30
EMBEDDINGS_RETRY_ATTEMPTS=2
EMBEDDINGS_RETRY_BACKOFF_MS=300
MAX_SEARCH_RESULTS=20
SEARCH_TIMEOUT_MS=5000
VECTOR_SIMILARITY_THRESHOLD=0.50

# ------------------------------------------
# LEADS Y BILLING
# ------------------------------------------
FREE_LEADS_DEFAULT=5
LEAD_DEDUPE_WINDOW_DAYS=7
FEEDBACK_DELAY_SECONDS=7200

# ------------------------------------------
# SEARCH CIRCUIT BREAKER
# ------------------------------------------
SEARCH_POOL_TIMEOUT_SECONDS=2
SEARCH_MAX_INFLIGHT=60
SEARCH_MAX_QUEUE=80
SEARCH_CB_FAILURE_THRESHOLD=5
SEARCH_CB_OPEN_SECONDS=20
SEARCH_CB_HALF_OPEN_SUCCESS_THRESHOLD=2
SEARCH_CANDIDATE_LIMIT=15

# ------------------------------------------
# WA-GATEWAY (Go + Meta Cloud API)
# ------------------------------------------
WA_GATEWAY_PORT=7000
WA_RATE_LIMIT_MAX_PER_HOUR=20
WA_RATE_LIMIT_MAX_PER24H=100

# ------------------------------------------
# WA-GATEWAY - WEBHOOK CONFIGURATION
# ------------------------------------------
AI_CLIENTES_URL=http://ai-clientes:8001
AI_PROVEEDORES_URL=http://ai-proveedores:8002
WEBHOOK_ENDPOINT=/handle-whatsapp-message
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_RETRY_ATTEMPTS=3
WA_META_WEBHOOK_ENABLED=false
WA_META_ENABLED_ACCOUNTS=bot-clientes
META_WEBHOOK_VERIFY_TOKEN=replace-with-verify-token
META_APP_SECRET=replace-with-meta-app-secret
META_PHONE_NUMBER_ID_CLIENTES=replace-with-meta-phone-number-id
META_PHONE_NUMBER_ID_PROVEEDORES=replace-with-meta-proveedores-phone-number-id
META_WABA_ID_CLIENTES=replace-with-meta-waba-id
META_WABA_ID_PROVEEDORES=replace-with-meta-proveedores-waba-id
WA_META_OUTBOUND_ENABLED=false
META_GRAPH_BASE_URL=https://graph.facebook.com
META_GRAPH_API_VERSION=v25.0
META_CLIENTES_ACCESS_TOKEN=replace-with-meta-clientes-access-token
META_PROVEEDORES_ACCESS_TOKEN=replace-with-meta-proveedores-access-token

# ------------------------------------------
# AI SERVICE PROVEEDORES
# ------------------------------------------
# Archivo origen: flows/onboarding/handlers/ciudad.py
# Descripción: URL reverse de Nominatim para resolver ciudad desde coordenadas
PROVIDER_NOMINATIM_REVERSE_URL=https://nominatim.openstreetmap.org/reverse
# Archivo origen: flows/onboarding/handlers/ciudad.py
# Descripción: URL search de Nominatim para resolver ciudad desde texto
PROVIDER_NOMINATIM_SEARCH_URL=https://nominatim.openstreetmap.org/search
# Archivo origen: flows/onboarding/handlers/ciudad.py
# Descripción: timeout HTTP en segundos para consultas a Nominatim
PROVIDER_NOMINATIM_TIMEOUT_SECONDS=2.5
# Archivo origen: templates/onboarding/consentimiento.py
# Descripción: URL de la política de privacidad mostrada en el consentimiento
PROVIDER_PRIVACY_POLICY_URL=https://www.tinku.bot/privacy
# Archivo origen: templates/onboarding/consentimiento.py
# Descripción: imagen que se muestra en el consentimiento de onboarding
PROVIDER_ONBOARDING_CONSENT_IMAGE_URL=https://euescxureboitxqjduym.supabase.co/storage/v1/object/sign/tinkubot-assets/images/tinkubot_providers_onboarding.png?token=eyJraWQiOiJzdG9yYWdlLXVybC1zaWduaW5nLWtleV8wMTQwMDNkYS1hOWY0LTQ1YmYtOTE1Zi1hZmYzZTExNDhhODciLCJhbGciOiJIUzI1NiJ9.eyJ1cmwiOiJ0aW5rdWJvdC1hc3NldHMvaW1hZ2VzL3Rpbmt1Ym90X3Byb3ZpZGVyc19vbmJvYXJkaW5nLnBuZyIsImlhdCI6MTc3Mjk1MDYyMiwiZXhwIjoxODM2MDIyNjIyfQ.J3a8O9wRoUo8PDwpcdv3KD5kPpfvKIONoIqXjsWORdI
# Archivo origen: infrastructure/redis/cliente_redis.py
# Descripción: timeout del socket de Redis en segundos
PROVIDER_REDIS_SOCKET_TIMEOUT_SECONDS=10
# Archivo origen: infrastructure/redis/cliente_redis.py
# Descripción: timeout de conexión de Redis en segundos
PROVIDER_REDIS_CONNECT_TIMEOUT_SECONDS=10
# Archivo origen: infrastructure/redis/cliente_redis.py
# Descripción: cantidad máxima de reintentos de conexión a Redis
PROVIDER_REDIS_MAX_RETRIES=3
# Archivo origen: infrastructure/openai/transformador_servicios.py
# Descripción: timeout en segundos para la transformación de servicios con OpenAI
PROVIDER_OPENAI_TRANSFORM_TIMEOUT_SECONDS=10.0
# Archivo origen: services/onboarding/registration/limpieza_onboarding_proveedores.py
# Descripción: timeout HTTP para enviar notificaciones de WhatsApp durante la limpieza de onboarding
PROVIDER_WHATSAPP_HTTP_TIMEOUT_SECONDS=10.0
# Archivo origen: flows/router.py
# Descripción: umbral en segundos para advertir inactividad del flujo
PROVIDER_INACTIVITY_WARNING_SECONDS=3600
PROVEEDORES_SERVER_PORT=8002
AI_SERVICE_PROVEEDORES_PORT=8002
AI_SERVICE_PROVEEDORES_URL=http://ai-proveedores:8002
AI_PROVEEDORES_INTERNAL_TOKEN=your-internal-token-here
PROVIDER_ONBOARDING_CLEANUP_INTERVAL_SECONDS=900
PROVIDER_ONBOARDING_WARNING_HOURS=48
PROVIDER_ONBOARDING_EXPIRY_HOURS=72
PROVIDER_MAX_SERVICES=10
PROVIDER_SERVICES_DISPLAY_ORDER_MAX=4

# ------------------------------------------
# AVAILABILITY
# ------------------------------------------
AVAILABILITY_TIMEOUT_SECONDS=180
TASK_POLL_INTERVAL_SECONDS=60

# ------------------------------------------
# SESSION Y FLOW
# ------------------------------------------
FLOW_TTL_SECONDS=86400

# ------------------------------------------
# UVICORN WORKERS (Por servicio)
# ------------------------------------------
AI_CLIENTES_UVICORN_WORKERS=2
AI_PROVEEDORES_UVICORN_WORKERS=2
AI_SEARCH_UVICORN_WORKERS=2
